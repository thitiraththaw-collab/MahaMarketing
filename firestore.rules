rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // -- HELPERS --
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'thitirath.thaw@gmail.com' && 
        request.auth.token.email_verified == true
      ); 
    }
    
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation Blueprint for Blog Post
    function isValidBlogPost(data) {
      return data.title is string && 
             data.slug is string && 
             data.content is string && 
             data.status in ['draft', 'published'];
    }

    // Validation Blueprint for Lead
    function isValidLead(data) {
      return data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.message is string && data.message.size() <= 2000;
    }

    // -- DEFAULT DENY --
    match /{document=**} {
      allow read, write: if false;
    }

    // -- SITE CONTENT --
    match /site/content {
      allow read: if true;
      allow write: if isAdmin();
    }

    // -- BLOG POSTS --
    match /posts/{postId} {
      allow get: if (isAdmin() || (resource != null && resource.data.status == 'published')) && isValidId(postId);
      allow list: if isAdmin() || (resource.data.status == 'published');
      allow create: if isAdmin() && isValidBlogPost(incoming());
      allow update: if isAdmin() && isValidBlogPost(incoming());
      allow delete: if isAdmin();
    }

    // -- LEADS --
    match /leads/{leadId} {
      allow create: if isValidLead(incoming()) && isValidId(leadId);
      allow read, update, delete: if isAdmin();
    }
  }
}
